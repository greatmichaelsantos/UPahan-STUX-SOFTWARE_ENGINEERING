{
  "name": "upahan",
  "version": "1.0.0",
  "private": true,
  "description": "Digital Apartment Management System for Zambales Properties",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "dev:mobile": "npm run start -w apps/mobile",
    "start": "npm run start -w apps/server",
    "build:web": "cd apps/web && npm run build",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "react": "18.2.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "4.4.0"
  }
}
